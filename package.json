    "express": "^5.2.1",
    "framer-motion": "^12.35.1",
    "html2pdf.js": "^0.14.0",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.577.0",
    "next": "16.1.6",
    "nodemailer": "^8.0.1",
    "openai": "^6.27.0",
