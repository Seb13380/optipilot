{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "outDir": "./dist/backend",
    "rootDir": "./",
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["backend/**/*", "src/lib/**/*", "prisma/**/*"],
  "exclude": ["node_modules", "src/app", "src/lib/opticianAuth.ts", "src/components"]
}
